# KB Search Configuration
PUBLIC_HOST=kb.local
KB_ROOT=/mnt/kb
KB_GARE_DIR=/mnt/kb/_Gare
KB_AQ_DIR=/mnt/kb/_AQ
ADMIN_TOKEN=change-me-please
EMBED_MODEL=BAAI/bge-m3
QDRANT_COLLECTION=kb_chunks

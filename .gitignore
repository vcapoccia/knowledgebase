# =======================================================================
.env
.env.local
.env.production
.env.staging
.env.development
.env.*.local
.environment

# Secret files
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# Configuration files with sensitive data
config/production/
config/staging/
config/secrets.yml
config/database.yml

# =======================================================================
# PYTHON

# =======================================================================
# SPECIAL INCLUSIONS
# =======================================================================

# Force include important empty directories
!docs/.gitkeep
!data/.gitkeep
!logs/.gitkeep
!temp/.gitkeep
!cache/.gitkeep
!backups/.gitkeep

# Keep important config templates
!config/templates/
!.env.example
!docker-compose.yml
!Dockerfile
!requirements*.txt

# Keep documentation
!README.md
!CHANGELOG.md
!LICENSE
!docs/*.md

# Keep scripts
!scripts/
!Makefile

# =======================================================================
# FINAL OVERRIDES
# =======================================================================

# If you need to include something that's normally ignored
# Prefix with ! (exclamation mark)
# Example: !important_file.log